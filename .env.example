# Required: Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: For live Telegram access. Get from https://my.telegram.org/
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: Override Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Embedding model used during ingest (default: text-embedding-004)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Optional: Batch size for embedding API calls during ingest (default: 100)
EMBEDDING_BATCH_SIZE=100

# Optional: Database path (default: chatlens.db in project root)
DB_PATH=chatlens.db
