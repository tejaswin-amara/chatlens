# Required: Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: For live Telegram access. Get from https://my.telegram.org/
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: Override Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: SQLAlchemy async database URL (PostgreSQL recommended for backend)
DATABASE_URL=******localhost:5432/chatlens

# Optional fallback DB path used when DATABASE_URL is not set
DB_PATH=chatlens.db
