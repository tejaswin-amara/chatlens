# Required: Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: For live Telegram access. Get from https://my.telegram.org/
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: Override Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Database connection (default: local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://chatlens:chatlens_password@localhost:5432/chatlens_db

# Celery broker (default: local Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
